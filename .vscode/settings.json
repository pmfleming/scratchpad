{
  "editor.formatOnSave": true,
  "editor.rulers": [
    100
  ],
  "files.eol": "\n",
  "files.readonlyInclude": {
    "**/.cargo/registry/src/**/*.rs": true,
    "**/.cargo/git/checkouts/**/*.rs": true,
    "**/rustup/toolchains/*/lib/rustlib/src/rust/library/**/*.rs": true
  },
  "rust-analyzer.check.command": "clippy"
}
