        "latency_kind": "first_response",
        "scaling_axis": "file_size",
        "threshold_ms": 6.0,
        "parameter_unit": "bytes",
        "query": "needle",
        "response_match_limit": 40,
        "description": "Initial keypress response for active-file search before the rest of the file finishes scanning"
    },
    "search_current_completion_file_size": {
        "targets": [
            "app::services::search",
            "app::domain::tab"
