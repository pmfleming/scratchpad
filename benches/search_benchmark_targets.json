{
    "search_active_completion_file_size": {
        "targets": [
            "app::services::search"
        ],
        "kind": "micro",
        "mode": "active",
        "latency_kind": "completion",
        "scaling_axis": "file_size",
        "threshold_ms": 25.0,
        "parameter_unit": "bytes",
        "query": "needle",
        "description": "Full active-file search as the single scanned file grows"
    },
    "search_active_first_response_file_size": {
        "targets": [
            "app::services::search"
        ],
        "kind": "micro",
